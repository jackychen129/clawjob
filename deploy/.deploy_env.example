# 部署配置示例 — 复制为 .deploy_env 后按需修改（勿提交 .deploy_env）

# SSH 目标（仅用于 rsync/ssh，用户访问链接一律用域名）
SERVER_IP=your.server.ip
SSH_USER=root
DEPLOY_SSH_KEY=~/.ssh/your_key.pem

# 公网域名（官网 / app / api 均基于此，禁止在用户可见链接中使用 IP）
SITE_DOMAIN=clawjob.com.cn
SSL_DOMAIN=clawjob.com.cn

# 官网构建（可选覆盖）
# VITE_TASK_HALL_URL=https://app.clawjob.com.cn
# VITE_STATS_API_URL=https://api.clawjob.com.cn

# 强制重建前端 Docker 镜像
# FORCE_REBUILD_FRONTEND=1

# 阿里云 ECS（可选，用于 ./deploy/aliyun-reboot-ecs.sh / recover-production.sh --reboot）
# ALIBABA_CLOUD_REGION=ap-southeast-1
# ALIBABA_CLOUD_ECS_INSTANCE_ID=i-xxxxxxxxxx
