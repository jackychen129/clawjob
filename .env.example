# ClawJob 环境变量示例（复制为 .env 后按需修改）
# 数据库（PostgreSQL）
DATABASE_URL=postgresql://clawjob:YOUR_DB_PASSWORD@localhost:5432/clawjob

# Redis
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0
# 或分项：
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# JWT（生产环境必须设置强随机密钥）
JWT_SECRET=your-very-long-random-secret-key-change-in-production

# CORS：生产环境填前端域名，逗号分隔，例如 https://clawjob.example.com
CORS_ORIGINS=

# 前端地址（用于 OAuth 回调等）
FRONTEND_URL=https://your-domain.com

# Google OAuth（可选；不配置则「使用 Google 登录」不可用）
# 在 Google Cloud Console 创建 OAuth 2.0 客户端，类型「Web 应用」；「授权重定向 URI」必须与 GOOGLE_REDIRECT_URI 完全一致
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 后端回调地址，本地开发填 http://localhost:8000/auth/google/callback（端口与后端一致）
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ChromaDB 持久化路径（可选）
CHROMA_DB_PATH=/app/data/chroma

# 社区聊天：后台定时刷新热度 + 热议站内信分发（设为 0 可关闭后台循环，仍可用 REST/W）
CLAWJOB_COMMUNITY_ENABLED=1
# 任务验收结案后是否在对应 Skill 话题自动生成一条闭环播报（本地建议 0；deploy/docker-compose.prod.yml 默认 1）
CLAWJOB_COMMUNITY_AUTO_POST_ON_COMPLETE=0
CLAWJOB_COMMUNITY_HOT_DISPATCH_ENABLED=1
CLAWJOB_COMMUNITY_BACKGROUND_JOBS=1
# 定时任务间隔（秒），最小 60；默认 900（15 分钟）
CLAWJOB_COMMUNITY_DISPATCH_INTERVAL_SEC=900
# 每轮最多刷新热度的话题数
CLAWJOB_COMMUNITY_HEAT_BATCH_LIMIT=300
# 每轮分发扫描的热门话题数、站内信上限
CLAWJOB_COMMUNITY_DISPATCH_TOP_LIMIT=5
CLAWJOB_COMMUNITY_DISPATCH_MAX_TARGETS=300

# 企业版功能（工作区 / 账单）；KYC 与提现为核心能力，无需本开关。默认 0。
CLAWJOB_ENTERPRISE=0

# 提现最低金额（任务点）、人工审核提示、手续费（基点，0=无）
WITHDRAWAL_MIN_AMOUNT=10
WITHDRAWAL_PROCESSING_HINT=T+3 工作日，人工审核后打款至收款账户
WITHDRAWAL_FEE_BP=0

# ---------- 前端构建时（Vite） ----------
# 前端打包时注入 API 地址，例如 https://api.your-domain.com
VITE_API_BASE_URL=http://localhost:8000
# 生产 canonical 域名（IP 访问时 API/跳转均使用此域，勿填 IP）
VITE_SITE_DOMAIN=clawjob.com.cn
